---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: `${base}`, label: '首页 / Home' },
  { href: `${base}articles/`, label: '文章 / Articles' },
  { href: `${base}submit/`, label: '投稿 / Submit' },
  { href: `${base}about/`, label: '关于 / About' },
];

function isActive(href: string) {
  if (href === base || href === `${base}`) {
    return currentPath === base || currentPath === `${base}` || currentPath === base.replace(/\/$/, '');
  }
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-(--color-bg-primary) border-b border-(--color-border) backdrop-blur-sm bg-opacity-95">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo / Wordmark -->
      <a href={base} class="flex items-center gap-2 text-(--color-text-primary) no-underline hover:text-(--color-text-primary)">
        <span class="text-2xl font-bold tracking-wider text-(--color-accent)" style="font-family: var(--font-serif);">DAMN</span>
        <span class="hidden sm:inline text-sm text-(--color-text-secondary)">《彻诞》</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 rounded text-sm transition-colors no-underline',
              isActive(item.href)
                ? 'text-(--color-accent) bg-(--color-bg-tertiary)'
                : 'text-(--color-text-secondary) hover:text-(--color-text-primary) hover:bg-(--color-bg-secondary)'
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-(--color-text-secondary) hover:text-(--color-text-primary)"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <nav id="mobile-menu" class="hidden md:hidden pb-4 border-t border-(--color-border)">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={[
            'block px-3 py-2 rounded text-sm transition-colors no-underline mt-1',
            isActive(item.href)
              ? 'text-(--color-accent) bg-(--color-bg-tertiary)'
              : 'text-(--color-text-secondary) hover:text-(--color-text-primary) hover:bg-(--color-bg-secondary)'
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
