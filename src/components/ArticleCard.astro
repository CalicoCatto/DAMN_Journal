---
interface Props {
  slug: string;
  title: string;
  authors: { name: string; affiliation: string }[];
  date: Date;
  abstract: string;
}

const { slug, title, authors, date, abstract } = Astro.props;
const base = import.meta.env.BASE_URL;
const dateStr = date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
const excerpt = abstract.length > 150 ? abstract.slice(0, 150) + '...' : abstract;
---

<a href={`${base}articles/${slug}/`} class="block no-underline group">
  <article class="border-l-3 border-(--color-accent) bg-(--color-bg-secondary) p-5 sm:p-6 rounded-r hover:bg-(--color-bg-tertiary) transition-colors">
    <h3 class="text-lg font-bold text-(--color-text-primary) group-hover:text-(--color-accent) transition-colors mb-2" style="font-family: var(--font-serif);">
      {title}
    </h3>
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-(--color-text-secondary) mb-3">
      <span>{authors.map(a => a.name).join(', ')}</span>
      <span>·</span>
      <time datetime={date.toISOString()}>{dateStr}</time>
    </div>
    <p class="text-sm text-(--color-text-secondary) leading-relaxed">
      {excerpt}
    </p>
  </article>
</a>
