---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="文章 / Articles — DAMN">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-2xl font-bold text-(--color-text-primary) mb-2" style="font-family: var(--font-serif);">
      文章 / Articles
    </h1>
    <p class="text-sm text-(--color-text-secondary) mb-8">
      共 {articles.length} 篇已发表文章 / {articles.length} published article{articles.length !== 1 ? 's' : ''}
    </p>

    {articles.length > 0 ? (
      <div class="space-y-4">
        {articles.map(article => (
          <ArticleCard
            slug={article.slug}
            title={article.data.title}
            authors={article.data.authors}
            date={article.data.date}
            abstract={article.data.abstract}
          />
        ))}
      </div>
    ) : (
      <div class="bg-(--color-bg-secondary) border border-(--color-border) rounded p-8 text-center">
        <p class="text-(--color-text-secondary)">暂无文章，敬请期待 / No articles yet, stay tuned.</p>
      </div>
    )}
  </section>
</BaseLayout>
